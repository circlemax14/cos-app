{
  "expo": {
    "name": "CSH",
    "slug": "cos",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "cos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.circlesupporthealth.csh",
      "buildNumber": "4",
      "associatedDomains": [
        "applinks:circlesupporthealth.ai",
        "applinks:*.circlesupporthealth.ai"
      ],
      "appleTeamId": "Y9J46AL3G2",
      "infoPlist": {
        "NSCameraUsageDescription": "Circle Support Health needs camera access to photograph documents and prescriptions.",
        "NSContactsUsageDescription": "Circle Support Health uses contacts to help you add emergency contacts quickly.",
        "NSPhotoLibraryUsageDescription": "Circle Support Health needs photo library access to upload health documents.",
        "NSFaceIDUsageDescription": "Circle Support Health uses Face ID to securely unlock your health information.",
        "NSHealthShareUsageDescription": "Circle Support Health reads your activity, heart rate, and sleep data to show a personalized daily health summary.",
        "NSHealthUpdateUsageDescription": "Circle Support Health updates your health data so your care team has the latest information.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "ai.circlesupporthealth.csh",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "circlesupporthealth.ai",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "*.circlesupporthealth.ai",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000,
      "url": "https://u.expo.dev/30bc49bd-ee12-4a06-86b3-ee4f23690114",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": "1.0.4",
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-font",
      "expo-image",
      "expo-tracking-transparency",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30bc49bd-ee12-4a06-86b3-ee4f23690114"
      }
    },
    "owner": "maximilien14s-organization"
  }
}
