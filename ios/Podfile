require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
  
  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'CSH' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # ── Generate dSYMs for prebuilt XCFrameworks ──────────────────────
    # Expo SDK 54 / RN 0.81 ships React.xcframework,
    # ReactNativeDependencies.xcframework, and hermes.xcframework as
    # stripped prebuilt binaries WITHOUT .dSYM bundles. Xcode then logs
    #   "Upload Symbols Failed - The archive did not include a dSYM..."
    # during archive upload. These warnings don't block release, but
    # without dSYMs Xcode cannot symbolicate crashes in those frameworks.
    # Fix: run dsymutil against each framework binary during archive and
    # drop the resulting .dSYM into the archive's dSYMs/ folder.
    installer.pods_project.targets.each do |target|
      next unless target.name == 'Pods-CSH'

      phase = target.new_shell_script_build_phase('Generate missing dSYMs for prebuilt XCFrameworks')
      phase.shell_script = <<~SH
        set -e

        # Only run during archive/device builds (have DWARF_DSYM_FOLDER_PATH).
        if [ -z "${DWARF_DSYM_FOLDER_PATH:-}" ]; then
          echo "Skipping dSYM generation (not an archive build)"
          exit 0
        fi

        # Only handle device slice; simulator builds don't need uploaded dSYMs.
        if [ "$PLATFORM_NAME" != "iphoneos" ]; then
          echo "Skipping dSYM generation (platform $PLATFORM_NAME != iphoneos)"
          exit 0
        fi

        PODS_ROOT="${PODS_ROOT:-${SRCROOT}/Pods}"
        mkdir -p "$DWARF_DSYM_FOLDER_PATH"

        generate_dsym() {
          local xcf_relpath="$1"
          local fw_name="$2"
          local slice="ios-arm64"
          local binary="$PODS_ROOT/$xcf_relpath/$slice/$fw_name.framework/$fw_name"
          local dsym_out="$DWARF_DSYM_FOLDER_PATH/$fw_name.framework.dSYM"

          if [ ! -f "$binary" ]; then
            echo "Skipping $fw_name — binary not found at $binary"
            return 0
          fi

          if [ -d "$dsym_out" ]; then
            echo "dSYM already exists for $fw_name"
            return 0
          fi

          echo "Generating dSYM for $fw_name..."
          dsymutil "$binary" -o "$dsym_out"
        }

        generate_dsym "React-Core-prebuilt/React.xcframework" "React"
        generate_dsym "ReactNativeDependencies/framework/packages/react-native/ReactNativeDependencies.xcframework" "ReactNativeDependencies"
        generate_dsym "hermes-engine/destroot/Library/Frameworks/universal/hermes.xcframework" "hermes"
      SH
      phase.run_only_for_deployment_postprocessing = '1'
    end
  end
end
